---
interface Props {
  maxYear?: number;
  minYear?: number;
}
---

<header class="mx-auto mt-4 mb-4 md:mb-6">
  <div class="flex flex-col items-center gap-2">
    <h1
      class="flex items-center gap-3 text-4xl md:text-5xl lg:text-6xl font-bold"
    >
      <img
        src="/favicon.png"
        alt=""
        class="h-12 w-12 shrink-0 md:h-14 md:w-14 lg:h-16 lg:w-16 rounded-sm"
        width="64"
        height="64"
      />
      <span>
        <span class="md:hidden">Finals MVP</span>
        <span class="hidden md:inline">Who should've won Finals MVP?</span>
      </span>
    </h1>
    <p class="text-center text-base md:text-lg text-white/70">
      A Machine Learning Classification Problem
    </p>
    <p class="flex items-center justify-center gap-1.5 text-sm text-white/55">
      <img
        src="/images/misc/bref.png"
        alt=""
        class="h-4 w-auto opacity-80"
        width="16"
        height="16"
      />
      powered by
      <a
        href="https://www.basketball-reference.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-white/55 hover:decoration-[#e0b86c]"
      >
        Basketball-Reference
        <span class="sr-only"> (opens in a new tab)</span>
      </a>
    </p>
    <p class="text-sm text-white/45 text-center">
      champion only · advanced stats era · 1984 - present
    </p>
  </div>
</header>
