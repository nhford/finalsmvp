---
import Layout from "@/layout/Layout.astro";
import Content from "@/features/standings/Content";
import HowItWorks from "@/features/how-it-works/HowItWorks";
import Footer from "@/layout/Footer";
import type { FinalsData } from "@/types/finals";
import finals from "@/data/finals.json";

const data = finals as FinalsData;
const correct = data.years.filter((y) => y.correct).length;
const featureWeights = data.featureWeights ?? [];
---

<Layout
  title="Finals MVP | Who should've won?"
  minYear={data.minYear}
  maxYear={data.maxYear}
>
  <div class="min-h-screen flex flex-col">
    <div class="flex flex-col md:flex-row md:gap-0 flex-grow">
      <div class="w-full md:flex-1 min-w-0">
        <h2 class="my-2 text-xl md:text-2xl lg:text-3xl text-center font-bold">
          Finals MVP Standings
        </h2>
        <p class="text-center text-sm md:text-base text-white/65 mb-2">
          {correct}/{data.years.length} years where the model matched the award (
          {data.minYear}–{data.maxYear})
        </p>
        <Content data={data} client:load />
      </div>

      <hr class="md:hidden w-full border-0 border-t border-white/30 my-2" />
      <div
        aria-hidden
        class="hidden md:block w-px shrink-0 self-stretch bg-white/30 mx-4 lg:mx-6"
      />

      <div class="w-full md:flex-1 min-w-0">
        <h2 class="my-2 text-xl md:text-2xl lg:text-3xl text-center font-bold">
          How It Works
        </h2>
        <HowItWorks
          client:load
          featureWeights={featureWeights}
          correct={correct}
          total={data.years.length}
          minYear={data.minYear}
          maxYear={data.maxYear}
        />
      </div>
    </div>
    <div class="mt-auto">
      <Footer client:only />
    </div>
  </div>
</Layout>
